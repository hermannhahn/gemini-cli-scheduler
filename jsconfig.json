{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2024",
		"jsx": "react-jsx",
		"allowImportingTsExtensions": true,
		"strictNullChecks": false,
		"strictFunctionTypes": false,
		"strict": false,
		"types": ["node"],
		"skipLibCheck": true,
		"maxNodeModuleJsDepth": 0
	},
	"include": ["**/*.js", "**/*.json"],
	"exclude": ["node_modules"]
}
